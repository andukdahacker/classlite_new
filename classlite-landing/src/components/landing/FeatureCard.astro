---
/**
 * FeatureCard — UX-DR14. Tinted background, title, description, 160px
 * preview area. The preview area holds an inline-SVG illustration
 * placeholder for v1 — illustrations themselves are OOS per
 * `1-10-followup-feature-illustrations`. Placeholder SVGs ship with
 * `aria-hidden="true"` per Sally DEFER #8 to pre-empt the axe
 * `image-alt` failure.
 */

type Tint = 'blue' | 'gold' | 'green'

interface Props {
  tint: Tint
  title: string
  body: string
}

const { tint, title, body } = Astro.props

const tintBackground: Record<Tint, string> = {
  blue: 'bg-[var(--cl-tint-blue)]',
  gold: 'bg-[var(--cl-tint-gold)]',
  green: 'bg-[var(--cl-tint-green)]',
}

const previewIconColor: Record<Tint, string> = {
  blue: 'text-[var(--cl-accent)]',
  gold: 'text-[var(--cl-accent-2)]',
  green: 'text-[var(--cl-green)]',
}
---

<article
  data-testid={`landing-feature-card-${tint}`}
  class={`flex flex-col rounded-2xl border border-[var(--cl-line)] ${tintBackground[tint]} p-6`}
>
  <h3
    class="mb-2 font-[var(--cl-font-display)] text-[20px] text-[var(--cl-ink)]"
  >
    {title}
  </h3>
  <p class="mb-4 text-sm leading-relaxed text-[var(--cl-muted)]">
    {body}
  </p>
  <div
    class={`mt-auto flex h-[160px] items-center justify-center rounded-lg bg-[var(--cl-surface)]/40 ${previewIconColor[tint]}`}
  >
    <svg
      width="64"
      height="64"
      viewBox="0 0 64 64"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <rect
        x="6"
        y="6"
        width="52"
        height="52"
        rx="6"
        stroke-dasharray="3 4"
      />
      <path d="M16 24h32M16 32h32M16 40h22" stroke-linecap="round" />
    </svg>
  </div>
</article>
