  canonicalUrl="https://classlite.app/vi/terms"
>
  <main class="mx-auto max-w-[680px] px-4 py-20 md:px-8">
    <h1
      class="mb-6 font-[var(--cl-font-display)] text-[28px] text-[var(--cl-ink)]"
    >
      Điều khoản
    </h1>
    <p class="text-sm text-[var(--cl-muted)]">
      Bản dự thảo — Story 1.10 follow-up <code>1-10-followup-legal-pages</code>.
      Bộ phận pháp lý đang chuẩn bị bản chính thức. v1 ra mắt với trang giữ chỗ
      này để các liên kết ở footer có đích hợp lệ.
    </p>
  </main>
</BaseLayout>
