---
import '../styles/tokens.css'
import '../styles/global.css'

interface Props {
  title: string
  lang?: string
}

const { title, lang = 'en' } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="dotted">
    <slot />
  </body>
</html>
