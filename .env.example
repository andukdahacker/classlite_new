# === Go API (classlite-api/) ===
PORT=8080
# Use classlite_app (non-superuser) for the application so RLS policies are enforced.
# Use classlite (superuser) only for running migrations.
DATABASE_URL=postgres://classlite_app:classlite_dev_password@localhost:5432/classlite_dev?sslmode=disable
MIGRATION_DATABASE_URL=postgres://classlite:classlite_dev_password@localhost:5432/classlite_dev?sslmode=disable
JWT_SECRET=dev-jwt-secret-change-in-production

# Google OAuth (story 1.6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
# HMAC secret used to sign the oauth_state cookie/token (≥ 32 bytes in non-dev).
OAUTH_STATE_SECRET=dev-oauth-state-secret-change-in-production-min-32
# Apex host that skips tenant-binding on OAuth callbacks (subdomain
# callbacks resolve their leading label to a center and run the
# membership check). Dev default: localhost:5173.
APP_APEX_HOST=localhost:5173
# Where successful OAuth callbacks land; appended with ?invited=...
# when an invite is accepted, or ?error=<code> for invite-recoverable failures.
APP_POST_LOGIN_URL=http://localhost:5173/
# Base URL for OAuth failure redirects (?error=<code> is appended).
APP_LOGIN_ERROR_URL_BASE=http://localhost:5173/login

# Resend (story 1.4)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@classlite.app
# Base URL embedded in verification emails (token is appended as ?token=<value>).
APP_VERIFY_URL_BASE=http://localhost:5173/verify-email
# Base URL embedded in password reset emails (token is appended as ?token=<value>).
APP_RESET_URL_BASE=http://localhost:5173/reset-password

# Cloudflare R2 (later stories)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=classlite-uploads

# Google Gemini (later stories)
GEMINI_API_KEY=

# Sentry
SENTRY_DSN=

# Polar.sh (epic 9)
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=

# Cookie domain
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# === React Dashboard (classlite-web/) ===
VITE_API_URL=http://localhost:8080
VITE_SENTRY_DSN=

# === Astro Landing (classlite-landing/) ===
# (No env vars needed for static build in MVP)
