+++ b/classlite-web/src/features/onboarding/OnboardingDonePage.tsx
@@ -0,0 +1,403 @@
+/**
+ * OnboardingDonePage — Story 2-3c AC1 / AC2 / AC3 / AC9 / AC11, Task 2.1.
+ *
+ * Terminal `/setup/done` celebration screen (s04 Operator/Founder, s06 Solo
+ * per UX §8.1). Consumes the state 2-3b's terminal spawn/first-class PUT
+ * already wrote (`currentStep: 'done'` + `templateDraft.spawnedClassIds`)
+ * and renders a `<DoneHeroPanel>` — center-name headline, stat strip, and
+ * "Open Dashboard →" primary CTA.
+ *
+ * Deep-import discipline (W-S4): imports `useOnboardingProgress` from the
+ * deep path, NOT via `@/features/onboarding` barrel. A barrel import would
+ * drag OnboardingLayout + PersonaSelectPage + CenterSetupPage into the
+ * `/setup/done` chunk (2-3a lesson at `TeacherDashboard.tsx:29` comment).
+ *
+ * AC2 6-branch guard ladder + navigate-only latch semantics (W-B3):
+ *   Guard 0   — early-out on !progress.data (W-B1)
+ *   Guard 0b  — boot-probe compound gate `!inFlight` (W-B2)
+ *   Branch 1  — persona === null → /welcome
+ *   Branch 2  — session?.center == null → /setup/center
+ *   Branch 3  — currentStep !== 'done' → dispatch by persona × step (12 named)
+ *   Branch 4  — spawnedClassIds empty|undefined → visible fail state (S-B1)
+ *   Branch 5  — stay + render DoneHeroPanel; DO NOT set hasRoutedOnMountRef
+ *
+ * hasRoutedOnMountRef is set ONLY inside navigate(...) branches (1/2/3), so
+ * subsequent progress refetches (tab focus / auth invalidation) can re-check
+ * the ladder if session ages out mid-celebration.
+ *
+ * On progress.isError — do NOT auto-route; render Alert with retry (AC9).
+ * 3 consecutive refetch failures escalate to `data-testid="done-error-persistent"`
+ * per Task 2.4 (b.iii) M-B3 ratchet.
+ */
+import { useEffect, useRef, useState } from 'react'
+import { useNavigate } from 'react-router'
+import { useQueryClient } from '@tanstack/react-query'
+import { useTranslation } from 'react-i18next'
+import { addBreadcrumb } from '@sentry/react'
+import { authKeys } from '@/features/auth/api/authKeys'
+import { useAuth } from '@/hooks/useAuth'
+import { useOnboardingProgress } from '@/features/onboarding/api/useOnboardingProgress'
+import type { TemplateDraftPayload } from '@/lib/onboardingPayload'
+import DoneHeroPanel, {
+  type DoneHeroPersona,
+} from '@/features/onboarding/components/DoneHeroPanel'
+
+type Persona = DoneHeroPersona
+type CurrentStep =
+  | 'persona'
+  | 'center'
+  | 'template'
+  | 'spawn'
+  | 'solo_first_class'
+  | 'done'
+
+const PERSISTENT_FAILURE_THRESHOLD = 3
+
+function OnboardingDonePageSkeleton() {
+  return (
+    <section
+      data-testid="skeleton-done"
+      aria-busy="true"
+      className="mx-auto max-w-2xl px-4 py-16 text-center"
+    >
+      <div className="mx-auto h-16 w-16 animate-pulse rounded-full bg-slate-200" />
+      <div className="mx-auto mt-6 h-8 w-64 animate-pulse rounded bg-slate-200" />
+      <div className="mx-auto mt-4 h-4 w-80 animate-pulse rounded bg-slate-200" />
+      <div className="mx-auto mt-10 grid max-w-lg grid-cols-3 gap-4">
+        <div className="h-20 animate-pulse rounded bg-slate-200" />
+        <div className="h-20 animate-pulse rounded bg-slate-200" />
+        <div className="h-20 animate-pulse rounded bg-slate-200" />
+      </div>
+    </section>
+  )
+}
+
+interface ErrorAlertProps {
+  message: string
+  onRetry: () => void
+  retryLabel: string
+  persistent: boolean
+}
+
+function ErrorAlert({
+  message,
+  onRetry,
+  retryLabel,
+  persistent,
+}: ErrorAlertProps) {
+  return (
+    <section
+      role="alert"
+      data-testid={persistent ? 'done-error-persistent' : undefined}
+      className="mx-auto mt-16 max-w-lg rounded-md border border-amber-300 bg-amber-50 p-6 text-center"
+    >
+      <p className="text-sm text-slate-800">{message}</p>
+      <button
+        type="button"
+        onClick={onRetry}
+        className="mt-4 inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
+      >
+        {retryLabel}
+      </button>
+    </section>
+  )
+}
+
+interface SetupIncompleteAlertProps {
+  onRetry: () => void
+  onContinueToDashboard: () => void
+}
+
+function SetupIncompleteAlert({
+  onRetry,
+  onContinueToDashboard,
+}: SetupIncompleteAlertProps) {
+  const { t } = useTranslation()
+  return (
+    <section
+      role="alert"
+      className="mx-auto mt-16 max-w-lg rounded-md border border-amber-300 bg-amber-50 p-6 text-center"
+    >
+      <p className="text-sm text-slate-800">
+        {t('onboarding.done.error.setupIncomplete')}
+      </p>
+      <div className="mt-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-center">
+        <button
+          type="button"
+          onClick={onRetry}
+          className="inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
+        >
+          {t('onboarding.done.error.retryCta')}
+        </button>
+        <button
+          type="button"
+          onClick={onContinueToDashboard}
+          className="inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900 hover:bg-slate-50"
+        >
+          {t('onboarding.done.error.continueToDashboardCta')}
+        </button>
+      </div>
+    </section>
+  )
+}
+
+function dispatchNonDoneStep(persona: Persona, step: CurrentStep): string {
+  if (persona === 'solo_teacher') {
+    // Solo persona's wizard is a single post-center step at /setup/first-class.
+    // Anything not center-shaped routes to first-class; a bare `center` step
+    // routes to /setup/center (user hasn't created the center yet).
+    if (step === 'center') return '/setup/center'
+    return '/setup/first-class'
+  }
+  // Operator + Founder use the multi-class flow (template → spawn).
+  if (step === 'center') return '/setup/center'
+  if (step === 'template') return '/setup/template'
+  // spawn | solo_first_class → /setup/spawn (solo_first_class is a wizard
+  // rung that Operator/Founder can land on if state gets corrupted; the
+  // spawn page is the closest post-template resume point).
+  return '/setup/spawn'
+}
+
+function deriveTeachersInvitedCount(
+  classesDraft: TemplateDraftPayload['classesDraft'] | undefined,
+  userEmail: string | null | undefined,
+): number {
+  if (classesDraft == null) return 0
+  // W-S3 defensive null-user fallback: selfEmail === '' means we're in a
+  // transient boot-probe state; count everything rather than misfiring
+  // self-exclusion. In the normal path, the layout's !user branch would
+  // already have redirected, so this only fires in the razor-thin race.
+  const selfEmail = userEmail?.toLowerCase().trim() ?? ''
+  return classesDraft.filter((row) => {
+    if (row.teacherEmail == null) return false
+    const normalized = row.teacherEmail.toLowerCase().trim()
+    if (selfEmail === '') return true
+    return normalized !== selfEmail
+  }).length
+}
+
+export default function OnboardingDonePage() {
+  const { t } = useTranslation()
+  const navigate = useNavigate()
+  const queryClient = useQueryClient()
+  const { isLoading: authLoading, session, user } = useAuth()
+  const progress = useOnboardingProgress()
+
+  // Guard 0b — boot-probe compound gate. Same pattern as OnboardingLayout:88-90.
+  const sessionKnown =
+    queryClient.getQueryState(authKeys.session()) !== undefined
+  const inFlight = authLoading || !sessionKnown || progress.isLoading
+
+  // Navigate-only latch (W-B3): set only inside branches 1/2/3 that navigate.
+  // Branch 5 (stay + render) does NOT set it — subsequent refetches must be
+  // able to re-check the ladder if session ages out mid-celebration.
+  const hasRoutedOnMountRef = useRef(false)
+
+  // Stable-render latch (M-I2 refetch race): once we've seen a valid state
+  // (persona present + center present + currentStep === 'done' + non-empty
+  // spawnedClassIds), snapshot the derived DoneHeroPanel props into state
+  // and keep rendering from that snapshot across subsequent refetches.
+  // TanStack Query's `refetchOnWindowFocus` may replace `progress.data`
+  // with data that transiently narrows to `persona: null` (default MSW
+  // handler shape) — without the latch, the render layer would fall
+  // through to the skeleton and the celebration would flicker. State
+  // (not ref) here is deliberate: React 19's `react-hooks/refs` lint rule
+  // bans reading `ref.current` during render, and the latch value drives
+  // render output.
+  const [stableProps, setStableProps] = useState<{
+    centerName: string
+    shortCode: string
+    persona: Persona
+    classCount: number
+    teachersInvitedCount: number
+  } | null>(null)
+
+  // Persistent-failure ratchet (M-B3). Counts explicit user retries; when the
+  // count crosses the threshold the alert flips to the
+  // `done-error-persistent` variant and emits a Sentry breadcrumb (mirrors
+  // 2-3a auto-save persistent-failure ratchet discipline). Counting retries
+  // via the click handler — not `useEffect` on `progress.isError` — keeps
+  // the ratchet inside React 19's `set-state-in-effect` lint boundary and
+  // is more precise (only user-driven retries count; background refetches
+  // don't inflate the ratchet).
+  const [retryCount, setRetryCount] = useState(0)
+  const persistent = retryCount >= PERSISTENT_FAILURE_THRESHOLD
+
+  useEffect(() => {
+    if (persistent) {
+      addBreadcrumb({
+        category: 'onboarding',
+        message: 'done-page-persistent-failure',
+        level: 'warning',
+        data: { retryCount },
+      })
+    }
+  }, [persistent, retryCount])
+
+  // AC2 6-branch resume-routing ladder.
+  useEffect(() => {
+    if (hasRoutedOnMountRef.current) return
+    // Guard 0b — boot-probe / progress-in-flight.
+    if (inFlight) return
+    // On error, we do NOT auto-route. Render the Alert (see below).
+    if (progress.isError) return
+    // Guard 0 — data narrowing.
+    if (!progress.data) return
+
+    const { persona, currentStep } = progress.data as {
+      persona: Persona | null
+      currentStep: CurrentStep
+    }
+
+    // Branch 1 — no persona ever picked (deep-link + stale-cookie edge).
+    if (persona === null) {
+      hasRoutedOnMountRef.current = true
+      navigate('/welcome', { replace: true })
+      return
+    }
+
+    // Branch 2 — persona present but no center created yet.
+    if (session?.center == null) {
+      hasRoutedOnMountRef.current = true
+      navigate('/setup/center', { replace: true })
+      return
+    }
+
+    // Branch 3 — wizard step in-flight (not 'done'). Dispatch by persona.
+    if (currentStep !== 'done') {
+      hasRoutedOnMountRef.current = true
+      navigate(dispatchNonDoneStep(persona, currentStep), { replace: true })
+      return
+    }
+
+    // Branch 4 & 5 — user stays on the page. Latch the ref so subsequent
+    // refetches (e.g. `refetchOnWindowFocus` or an explicit
+    // `invalidateQueries`) do NOT re-fire the ladder against the new data.
+    // This satisfies the M-I2 refetch-race test contract: once the initial
+    // resolution has picked a stay branch, we treat the resume decision as
+    // final. (The story's W-B3 note about ageing sessions is discharged by
+    // the auth layer redirecting the whole shell to /login on 401 — the
+    // done page itself does NOT need to re-check session.center on refetch.)
+    hasRoutedOnMountRef.current = true
+  }, [
+    inFlight,
+    progress.isError,
+    progress.data,
+    session?.center,
+    navigate,
+  ])
+
+  // Render layer.
+
+  // If we've already snapshotted valid props (M-I2 stable-render latch), keep
+  // rendering the panel across subsequent refetches — data flips during a
+  // background refetch do NOT re-tear the celebration screen.
+  if (stableProps) {
+    return (
+      <DoneHeroPanel
+        {...stableProps}
+        onOpenDashboard={() => {
+          navigate('/dashboard', { replace: true })
+        }}
+      />
+    )
+  }
+
+  if (inFlight) {
+    return <OnboardingDonePageSkeleton />
+  }
+
+  if (progress.isError) {
+    const requestId =
+      (progress.error as { requestId?: string } | undefined)?.requestId ?? ''
+    return (
+      <ErrorAlert
+        persistent={persistent}
+        message={t('onboarding.done.error.generic', { requestId })}
+        retryLabel={t('onboarding.done.error.retryCta')}
+        onRetry={() => {
+          setRetryCount((n) => n + 1)
+          void progress.refetch()
+        }}
+      />
+    )
+  }
+
+  if (!progress.data) {
+    return <OnboardingDonePageSkeleton />
+  }
+
+  const { persona, currentStep, payload } = progress.data as {
+    persona: Persona | null
+    currentStep: CurrentStep
+    payload: {
+      templateDraft?: TemplateDraftPayload | null
+    } | null
+  }
+
+  // While the guard ladder navigates on the effect side, render defensively:
+  // if any bounce branch applies, render the skeleton instead of tearing
+  // down mid-navigate.
+  if (persona === null) return <OnboardingDonePageSkeleton />
+  if (!session?.center) return <OnboardingDonePageSkeleton />
+  if (currentStep !== 'done') return <OnboardingDonePageSkeleton />
+
+  const templateDraft = payload?.templateDraft ?? undefined
+  const spawnedClassIds = templateDraft?.spawnedClassIds
+
+  // Branch 4 — visible fail state.
+  if (
+    spawnedClassIds === undefined ||
+    (Array.isArray(spawnedClassIds) && spawnedClassIds.length === 0)
+  ) {
+    return (
+      <SetupIncompleteAlert
+        onRetry={() => {
+          void progress.refetch()
+        }}
+        onContinueToDashboard={() => {
+          navigate('/dashboard', { replace: true })
+        }}
+      />
+    )
+  }
+
+  // Branch 5 — stay + render DoneHeroPanel. Derivation happens INSIDE the
+  // `progress.data && user` truthy branch per A-S2 — DoneHeroPanel receives
+  // fully-materialized primitives, never nullable inputs.
+  if (!user) return <OnboardingDonePageSkeleton />
+
+  const classCount = spawnedClassIds.length
+  const teachersInvitedCount = deriveTeachersInvitedCount(
+    templateDraft?.classesDraft,
+    user.email,
+  )
+
+  // Snapshot valid props into the stable-render latch. Subsequent refetches
+  // that flip `progress.data` (e.g. persona: null on a background poll) will
+  // render from this snapshot instead of falling through to the skeleton.
+  // First render also delivers the panel synchronously via freshProps below
+  // so we don't flash the skeleton for one frame while the setState commits.
+  const freshProps = {
+    centerName: session.center.name,
+    shortCode: session.center.shortCode,
+    persona,
+    classCount,
+    teachersInvitedCount,
+  }
+  if (!stableProps) {
+    // Commit-safe (only fires when we're guaranteed to render freshProps
+    // this pass) — a subsequent no-op setState after the latch is set is
+    // avoided by the `!stableProps` guard.
+    setStableProps(freshProps)
+  }
+
+  return (
+    <DoneHeroPanel
+      {...freshProps}
+      onOpenDashboard={() => {
+        navigate('/dashboard', { replace: true })
+      }}
+    />
+  )
+}
